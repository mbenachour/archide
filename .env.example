# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "openai" or "ollama"
PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_TOKEN=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Ollama (local / self-hosted) ──────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_API_TOKEN=
# OLLAMA_MODEL=qwen3.5:397b-cloud

# ── GitHub ────────────────────────────────────────────────────────────────────
# Required for private repos. Recommended for public repos to avoid rate limits.
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=github_pat_...
